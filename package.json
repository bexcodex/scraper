{
  "name": "@bexcodex/scraper",
  "version": "0.0.1",
  "description": "bexcodex scraper",
  "license": "MIT",
  "author": "bexcodex",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bexcodex/scraper.git"
  },
  "bugs": {
    "url": "https://github.com/bexcodex/scraper/issues"
  },
  "homepage": "https://github.com/bexcodex/scrape#readme",
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "generate:exports": "bun run scripts/generate-exports.ts",
    "build": "bun run clean && bun run generate:exports && tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.1.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
